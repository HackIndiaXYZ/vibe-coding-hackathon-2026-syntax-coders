NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lifelink?schema=public"
JWT_ACCESS_SECRET="replace-with-a-long-random-access-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
SEED_ADMIN_NAME="LifeLink Admin"
SEED_ADMIN_EMAIL="admin@lifelink.local"
SEED_ADMIN_PASSWORD="change-this-admin-password"

# Groq AI
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# Pinata IPFS
PINATA_API_KEY="your-pinata-api-key"
PINATA_API_SECRET="your-pinata-api-secret"
PINATA_JWT="your-pinata-jwt"

# Blockchain Consent
SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
CONSENT_CONTRACT_ADDRESS="0x_your_deployed_contract_address"
BACKEND_WALLET_PRIVATE_KEY="0x_your_backend_wallet_private_key"
